{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "osim-engine:streaming/gantt_durchlauf.json",
  "title": "gantt_durchlauf frame",
  "description": "Sub-Stream gantt_durchlauf (SPEC 6.3): Prozess start/ende eines Durchlaufplans.",
  "type": "object",
  "required": ["t", "stream", "seq", "v"],
  "properties": {
    "t": { "type": "integer" },
    "stream": { "const": "gantt_durchlauf" },
    "seq": { "type": "integer" },
    "wall_t": { "type": "string" },
    "meta_event": { "type": "string" },
    "v": {
      "type": "object",
      "required": ["kind", "auftrag_id", "prozess_id", "start_time"],
      "properties": {
        "kind": { "enum": ["start", "ende"] },
        "auftrag_id": { "type": ["string", "null"] },
        "prozess_id": { "type": ["string", "null"] },
        "start_time": { "type": ["integer", "null"] },
        "betriebsmittel_id": { "type": ["string", "null"] },
        "dauer_geplant": { "type": ["integer", "null"] },
        "end_time": { "type": "integer" },
        "dauer_ist": { "type": ["integer", "null"] },
        "status": { "type": "string" },
        "partial": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "ende" } } },
          "then": { "required": ["end_time", "status"] }
        }
      ]
    }
  }
}
