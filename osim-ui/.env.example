# Datenbank
DATABASE_URL=postgresql+asyncpg://osim_dev:osim_dev_password@localhost:5432/osim_ui
DATABASE_DEFAULT_SCHEMA=public

# Firebase (Dev nutzt Emulator)
FIREBASE_PROJECT_ID=osim-dev
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# Object Storage (Dev nutzt Minio oder lokales Filesystem)
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./local-storage
# Prod:
# STORAGE_BACKEND=gcs
# STORAGE_GCS_BUCKET=osim-ui-dev

# CORS
CORS_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=INFO
ENVIRONMENT=dev

# Engine-Pfad (lokal, falls nicht installiert)
# OSIM_ENGINE_PATH=../osim-engine

# Worker-Limits
WORKER_MAX_PARALLEL=4
WORKER_TIMEOUT_SECONDS=600
