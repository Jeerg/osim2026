# --- Datenbank ---------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://osim_dev:osim_dev_password@localhost:5432/osim_ui
DATABASE_DEFAULT_SCHEMA=public

# --- Firebase ----------------------------------------------------------------
# Dev nutzt den lokalen Emulator aus docker-compose.
FIREBASE_PROJECT_ID=osim-dev
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# --- CORS --------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# --- Object Storage ----------------------------------------------------------
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=./local-storage
# Prod:
# STORAGE_BACKEND=gcs
# STORAGE_GCS_BUCKET=osim-ui-prod
# Minio (lokaler S3-Emulator):
# STORAGE_BACKEND=minio
# STORAGE_MINIO_ENDPOINT=localhost:9000
# STORAGE_MINIO_ACCESS_KEY=osim_dev
# STORAGE_MINIO_SECRET_KEY=osim_dev_password
# STORAGE_MINIO_BUCKET=osim-ui

# --- Worker ------------------------------------------------------------------
WORKER_MAX_PARALLEL=4
WORKER_TIMEOUT_SECONDS=600

# --- Logging & Environment --------------------------------------------------
ENVIRONMENT=dev
LOG_LEVEL=INFO
