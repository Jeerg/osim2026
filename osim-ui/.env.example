# osim-ui Phase 1 — Dev-Defaults; Production-Werte in Secret-Manager (Phase 5)
#
# Hinweis: PYTHONPATH sollte NICHT gesetzt sein, sonst kann ein
# konkurrierendes `tests`-Package eines anderen Projekts (z.B. 3fls) shadowen.
# (Vorgemerkt aus Plan 01-01-SUMMARY § Issues Encountered.)

# --- Datenbank ---------------------------------------------------------------
# 3fls-Stack-Parität: sync psycopg3 statt async asyncpg (D-18, 2026-05-21).
DATABASE_URL=postgresql+psycopg://osim_dev:osim_dev_password@localhost:5432/osim_ui

# --- Firebase Auth -----------------------------------------------------------
FIREBASE_PROJECT_ID=osim-dev
# Dev nutzt Emulator; in Produktion diese Variable NICHT setzen (Application
# Default Credentials greifen dann). Pitfall #9: nie in Prod-Deploy übernehmen.
# Host-Port 19099 (statt 9099), weil tbx_stzrim-Emulator parallel auf 9099 läuft.
FIREBASE_AUTH_EMULATOR_HOST=localhost:19099

# --- Environment / CORS -----------------------------------------------------
ENVIRONMENT=dev
# Vite-Dev-Server-Ports (3fls nutzt 3000; osim-ui zusätzlich 3002 frei)
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# --- Object Storage (Minio lokal über S3-API) -------------------------------
STORAGE_BACKEND=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=osim_dev
MINIO_SECRET_KEY=osim_dev_password
MINIO_BUCKET=osim-ui-dev

# --- Single-Editor-Lock (D-13: 15 min Max-Inaktivität) ----------------------
LOCK_TTL_SECONDS=60
LOCK_MAX_INACTIVITY_SECONDS=900
