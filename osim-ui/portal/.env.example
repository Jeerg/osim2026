# Portal-Environment.
# Lokale Entwicklung kommt mit den Defaults aus; in prod muessen alle
# VITE_FIREBASE_*-Werte aus dem echten Firebase-Projekt eingetragen werden.

# Backend-Base-URL fuer apiFetch + /auth/me.
VITE_API_BASE_URL=http://localhost:8000

# Firebase-Client-Konfig (Dev: Emulator akzeptiert alles, ABER projectId MUSS
# mit dem Backend (osim-ui/.env -> FIREBASE_PROJECT_ID=osim-dev) matchen,
# sonst lehnt das Backend Tokens mit "Audience-Mismatch" als 401 ab.
VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=osim-dev.local
VITE_FIREBASE_PROJECT_ID=osim-dev
