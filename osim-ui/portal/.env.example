# osim-ui Portal — Frontend-Env-Variablen.
# Lokale Entwicklung: dieses File nach `.env.local` kopieren und anpassen.
# Produktion: Werte via CI/CD-Secret-Store setzen (kein Commit).

# Firebase-Client-Config (Public-by-Design — Domain-Whitelist im Firebase-
# Project schützt). Demo-Werte funktionieren mit dem lokalen Emulator.
VITE_FIREBASE_API_KEY=demo-api-key-for-emulator
VITE_FIREBASE_AUTH_DOMAIN=osim-dev.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=osim-dev

# Backend-API-Basis-URL — Default für lokales `uv run uvicorn app.main:app`.
VITE_API_BASE_URL=http://localhost:8000
